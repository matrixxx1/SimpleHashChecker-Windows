<Window x:Class="SimpleHashChecker.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="m3Coding: Simple Hash Checker"
        Width="1060"
        Height="680"
        MinWidth="760"
        MinHeight="560"
        Background="#F4F5F7"
        AllowDrop="True"
        DragOver="Window_DragOver"
        Drop="Window_Drop">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderBrush" Value="#C8CCD4" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="Background" Value="#1F6FEB" />
            <Setter Property="BorderBrush" Value="#1F6FEB" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="BorderBrush" Value="#C8CCD4" />
            <Setter Property="Background" Value="#FFFFFF" />
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,14">
            <Button DockPanel.Dock="Right"
                    Style="{StaticResource PrimaryButton}"
                    Click="BrowseButton_Click"
                    Content="Browse for file" />
            <StackPanel>
                <TextBlock Text="Simple Hash Checker"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="#172033" />
                <TextBlock Text="Drop a file here, or browse, then calculate MD5, SHA1, SHA256, or SHA512."
                           Margin="0,6,0,0"
                           Foreground="#596579"
                           FontSize="14" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1"
                BorderBrush="#D8DDE7"
                BorderThickness="1"
                Background="#FFFFFF"
                CornerRadius="8"
                Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        BorderBrush="#9EB4D8"
                        BorderThickness="2"
                        CornerRadius="8"
                        Background="#F8FBFF"
                        Padding="18"
                        MinHeight="92">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock x:Name="FileNameText"
                                       Text="No file selected"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Foreground="#172033"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock x:Name="FileDetailsText"
                                       Text="Drag and drop a file onto this window."
                                       Margin="0,8,0,0"
                                       Foreground="#596579" />
                            <TextBlock x:Name="FilePathText"
                                       Margin="0,4,0,0"
                                       Foreground="#596579"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="DROP FILE"
                                   VerticalAlignment="Center"
                                   Foreground="#1F6FEB"
                                   FontWeight="Bold"
                                   Margin="24,0,0,0" />
                    </Grid>
                </Border>

                <UniformGrid Grid.Row="1"
                             Columns="4"
                             Margin="0,16,0,10">
                    <Button Content="MD5" Margin="0,0,8,0" Click="HashButton_Click" Tag="MD5" />
                    <Button Content="SHA1" Margin="8,0,8,0" Click="HashButton_Click" Tag="SHA1" />
                    <Button Content="SHA256" Margin="8,0,8,0" Click="HashButton_Click" Tag="SHA256" />
                    <Button Content="SHA512" Margin="8,0,0,0" Click="HashButton_Click" Tag="SHA512" />
                </UniformGrid>

                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="HashHeadingText"
                               Text="Calculated hash"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#172033"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="Copy to clipboard"
                            Click="CopyButton_Click" />
                </Grid>

                <TextBox x:Name="HashTextBox"
                         Grid.Row="3"
                         FontFamily="Consolas"
                         FontSize="16"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         Height="82"
                         Text="Select a file and choose a hash type." />

                <Grid Grid.Row="4" Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Expected hash"
                               FontWeight="SemiBold"
                               Foreground="#172033" />
                    <TextBlock x:Name="CompareStatusText"
                               Grid.Column="1"
                               Margin="18,0,0,0"
                               VerticalAlignment="Center"
                               FontWeight="Bold"
                               Foreground="#596579"
                               Text="Waiting" />
                    <Grid Grid.Row="1"
                          Grid.ColumnSpan="2"
                          Margin="0,8,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBox x:Name="ExpectedHashTextBox"
                                 TextChanged="ExpectedHashTextBox_TextChanged"
                                 FontFamily="Consolas"
                                 MinHeight="42" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="180" />
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText"
                       Foreground="#596579"
                       VerticalAlignment="Center"
                       Text="Ready" />
            <ProgressBar x:Name="HashProgressBar"
                         Grid.Column="1"
                         Height="8"
                         Minimum="0"
                         Maximum="100"
                         Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
